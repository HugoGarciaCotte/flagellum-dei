{
  "publicAnonKey": "aix_jtfkxaj4v7ceb6k8z9j4qd8rxmh75c2t",
  "version": 1,
  "framework": "react-router",
  "defaultLocale": "en",
  "locales": ["en", "fr"],
  "routing": "path",
  "pathNormalizationRules": [
    {
      "pattern": "[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}",
      "replacement": ":id"
    }
  ],
  "routes": [
    { "path": "/", "kind": "static" },
    { "path": "/auth", "kind": "static" },
    { "path": "/game/[gameId]/host", "kind": "dynamic", "params": ["gameId"] },
    { "path": "/game/[gameId]/play", "kind": "dynamic", "params": ["gameId"] },
    { "path": "/reset-password", "kind": "static" },
    { "path": "/install", "kind": "static" },
    { "path": "/admin", "kind": "static" },
    { "path": "/admin/feats", "kind": "static" },
    { "path": "/admin/scenarios", "kind": "static" }
  ],
  "pages": []
}
